{
    "compilerOptions": {
        "declaration": true,
        "outDir": "build",
        "rootDir": "src",
        "module": "commonjs",
        "target": "es6",
        "esModuleInterop": true,
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "build"
    ]
}